              {
                "flag": "regex",
                "constraint": {
                  "pattern": "/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/",
                  "name": "Must be a valid email address",
                  "invert": false
                }
              }
            ],
            "level": "error"
          }
        ],
        "name": "email",
        "type": "string",
        "title": "Email Address"
      },
      {
